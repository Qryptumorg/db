{
  "name": "qryptum-db",
  "version": "1.0.0",
  "description": "Qryptum database schema using Drizzle ORM and PostgreSQL",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "generate": "drizzle-kit generate --config ./drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.43.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.3"
  }
}
